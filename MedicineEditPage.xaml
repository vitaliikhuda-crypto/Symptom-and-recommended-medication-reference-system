<Page x:Class="MedSearchWPF.Views.MedicineEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MedSearchWPF.ViewModels"
      Title="Препарати">

    <Page.DataContext>
        <vm:MedicineEditViewModel/>
    </Page.DataContext>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Препарати" FontWeight="Bold" Margin="0,0,0,6"/>

            <ListView ItemsSource="{Binding Medicines}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      Height="260">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding Name}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="➕ Додати"   Command="{Binding AddCommand}"    Margin="0,0,4,0"/>
                <Button Content="🗑️ Видалити" Command="{Binding RemoveCommand}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="16,0,0,0">
            <TextBlock Text="Редагування" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Назва:"/>
            <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Text="Опис:"/>
            <TextBox Text="{Binding EditDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Text="Доза:"/>
            <TextBox Text="{Binding EditDose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Text="Іконка:"/>
            <TextBox Text="{Binding EditIcon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"/>

            <Button Content="💾 Застосувати зміни"
                    Command="{Binding ApplyCommand}"
                    HorizontalAlignment="Left" Padding="12,6"/>

            <TextBlock Text="{Binding Status, Mode=OneWay}"
                       Margin="0,12,0,0" FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Page>
