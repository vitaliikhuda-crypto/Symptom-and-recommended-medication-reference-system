<Window x:Class="MedSearchWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedSearch"
        Width="800" Height="500"
        MinWidth="600" MinHeight="400">

    <DockPanel>

        < Верхнє меню >
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="LightGray">
            <Button Content="Головна" Width="100" Margin="5"/>
            <Button Content="Симптоми" Width="100" Margin="5"/>
            <Button Content="Налаштування" Width="120" Margin="5"/>
        </StackPanel>

        <!-- Нижня панель -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="Готово"/>
        </StatusBar>

        < Основний контент >
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            < Заголовок>
            <TextBlock Text="МедПошук"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            < Поле вводу >
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20">
                <Label Content="Симптом:" Width="100"/>
                <TextBox x:Name="SymptomTextBox" Width="200"/>
            </StackPanel>

            < Результат >
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
                <Label Content="Результат:" Width="100"/>
                <TextBox x:Name="ResultTextBox" Width="200"/>
            </StackPanel>

            < Кнопки >
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20">
                <Button Content="Пошук" Width="100" Margin="5" Click="Search_Click"/>
                <Button Content="Очистити" Width="100" Margin="5" Click="Clear_Click"/>
                <Button Content="Інфо" Width="100" Margin="5" Click="Info_Click"/>
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>
